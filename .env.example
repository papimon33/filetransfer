# ── QR 업로드 서버 환경변수 예시 ──
# 실제 사용 시 이 파일을 복사해 값을 채우고, 셸에서 export 하거나 Render 대시보드에 등록하세요.
# (python-dotenv를 쓰지 않으므로 로컬에서는 환경변수로 직접 주입해야 합니다.)

# 폰 QR이 가리킬 공개 주소. Render면 https://<앱>.onrender.com
# 로컬 LAN 테스트면 http://<PC의 LAN IP>:8000  (미설정 시 LAN IP 자동감지)
BASE_URL=

# 서버 바인딩
HOST=0.0.0.0
PORT=8000

# 토큰 저장소: MongoDB Atlas (설정하면 토큰이 DB에 영구 저장 — Render 재배포에도 유지).
# 비우면 아래 TOKENS_FILE(파일)로 저장(로컬 개발용).
#   예: mongodb+srv://papimon11:<db_password>@cluster0.t4fakwg.mongodb.net/?appName=Cluster0
MONGODB_URI=
MONGODB_DB=filetransfer

# 사번 자가발급(/enroll) 가입코드. 설정하면 사번 발급 시 이 코드도 요구. 비우면 사번만으로 발급.
ENROLL_KEY=

# 파일 저장 경로 (MONGODB_URI 미설정 시 토큰 저장 + 업로드/QR 저장)
UPLOAD_DIR=./uploads
TOKENS_FILE=./tokens.json
QR_DIR=./qrcodes

# 업로드 제한
ALLOWED_EXT=jpg,jpeg,png,heic,webp
MAX_FILE_MB=30

# 자동 삭제
RETENTION_HOURS=6
CLEANUP_INTERVAL_MIN=30

# 관리 콘솔 접근. /admin 접속 → 아래 비밀번호로 로그인(세션 쿠키). URL에 키를 붙이지 않음.
# ADMIN_PASSWORD 를 기억하기 쉬운 값으로 설정하세요. (미설정 시 ADMIN_KEY 가 비밀번호로 사용됨)
# 둘 다 비우면 /admin 비활성화(404).
ADMIN_PASSWORD=
ADMIN_KEY=

# 다운로드한 파일을 서버에서 자동 삭제(소비형). 기본 true.
# false 로 두면 다운로드해도 서버에 남습니다.
DELETE_ON_DOWNLOAD=true

# 개인 PIN 게이트 (기본 off). on이면 PIN이 설정된 토큰은 PIN 입력 후 접근.
REQUIRE_PIN=false
# PIN 세션 쿠키 서명 키. PIN을 쓰고 재시작 후에도 세션 유지하려면 고정값 지정.
SESSION_SECRET=

# 시작 시 콘솔에 ASCII QR 출력 여부
PRINT_QR_ON_START=true

# 고정 토큰(중요, Render 무료 플랜 권장). 형식: "토큰=이름,토큰=이름"
# 로컬에서 `python app.py issue --name "홍길동"` 으로 토큰을 만든 뒤,
# 출력된 토큰 문자열을 여기에 붙여 넣으면 서버 재시작/재배포 후에도 동일 토큰이 유지됩니다.
# (파일시스템이 임시라도 환경변수는 유지되므로)
PRESET_TOKENS=
