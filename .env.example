# ── QR 업로드 서버 환경변수 예시 ──
# 실제 사용 시 이 파일을 복사해 값을 채우고, 셸에서 export 하거나 Render 대시보드에 등록하세요.
# (python-dotenv를 쓰지 않으므로 로컬에서는 환경변수로 직접 주입해야 합니다.)

# 폰 QR이 가리킬 공개 주소. Render면 https://<앱>.onrender.com
# 로컬 LAN 테스트면 http://<PC의 LAN IP>:8000  (미설정 시 LAN IP 자동감지)
BASE_URL=

# 서버 바인딩
HOST=0.0.0.0
PORT=8000

# 저장 경로
UPLOAD_DIR=./uploads
TOKENS_FILE=./tokens.json
QR_DIR=./qrcodes

# 업로드 제한
ALLOWED_EXT=jpg,jpeg,png,heic,webp
MAX_FILE_MB=30

# 자동 삭제
RETENTION_HOURS=6
CLEANUP_INTERVAL_MIN=30

# 개인 PIN 게이트 (기본 off). on이면 PIN이 설정된 토큰은 PIN 입력 후 접근.
REQUIRE_PIN=false
# PIN 세션 쿠키 서명 키. PIN을 쓰고 재시작 후에도 세션 유지하려면 고정값 지정.
SESSION_SECRET=

# 시작 시 콘솔에 ASCII QR 출력 여부
PRINT_QR_ON_START=true

# 고정 토큰(중요, Render 무료 플랜 권장). 형식: "토큰=이름,토큰=이름"
# 로컬에서 `python app.py issue --name "홍길동"` 으로 토큰을 만든 뒤,
# 출력된 토큰 문자열을 여기에 붙여 넣으면 서버 재시작/재배포 후에도 동일 토큰이 유지됩니다.
# (파일시스템이 임시라도 환경변수는 유지되므로)
PRESET_TOKENS=
